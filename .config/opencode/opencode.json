{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "default_agent": "plan",
  "share": "disabled",
  "autoupdate": false,
  "snapshot": false,
  "agent": {
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "todowrite": "allow",
        "task": "deny",
        "skill": "deny",
        "external_directory": "deny"
      }
    },
    "build": {
      "disable": false,
      "permission": {
        "edit": "ask",
        "bash": "deny",
        "todowrite": "allow",
        "task": "deny",
        "skill": "deny",
        "external_directory": "deny"
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "ask",
    "bash": "deny",
    "todowrite": "deny",
    "task": "deny",
    "skill": "deny",
    "external_directory": "deny",
    "webfetch": "allow",
    "websearch": "allow"
  }
}
